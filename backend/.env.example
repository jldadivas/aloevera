# Vera Backend - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Local MongoDB
# NOTE: backend accepts either MONGO_URI or MONGODB_URI.
MONGO_URI=mongodb://localhost:27017/vera
MONGODB_URI=mongodb://localhost:27017/vera
DB_NAME=vera

# OR MongoDB Atlas (recommended for production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vera?retryWrites=true&w=majority
# DB_NAME=vera

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_here_min_32_chars
JWT_EXPIRE=7d

# ============================================
# CLOUDINARY (Image CDN)
# ============================================
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789123456789
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz

# ============================================
# ML SERVICE CONFIGURATION
# ============================================
# URL where ML service is running
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=30000

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# Allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# ============================================
# ADMIN ACCOUNT
# ============================================
# Initial admin credentials (used in seeders)
ADMIN_EMAIL=admin@vera.com
ADMIN_PASSWORD=AdminPassword123!

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================
# For notifications (optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ============================================
# OPTIONAL: LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# OPTIONAL: RATE LIMITING
# ============================================
# Rate limit in requests per windowMs
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FIREBASE ADMIN (GOOGLE SIGN-IN VERIFICATION)
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real values
# 2. Use strong passwords in production
# 3. Rotate secrets periodically
# 4. Use environment variables, not hardcoded values
# 5. For production, use managed services (Atlas, Cloudinary, etc.)
# 6. In production, required non-empty vars are validated at startup:
#    MONGODB_URI, JWT_SECRET, CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY,
#    CLOUDINARY_API_SECRET, ML_SERVICE_URL, CORS_ORIGIN
